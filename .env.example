# ── Copy this file to .env and fill in your values ──────────────
# Then load with: pip install python-dotenv
# And add to app.py: from dotenv import load_dotenv; load_dotenv()

# Flask
SECRET_KEY=change-this-to-a-random-string-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# Database — format: mysql+pymysql://user:password@host/dbname
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost/crypto_tracker

# JWT
JWT_SECRET_KEY=another-random-secret-for-jwt-tokens

# Optional: CoinGecko API Key (free tier works without it)
# COINGECKO_API_KEY=your_api_key_here
